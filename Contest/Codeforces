    public static void War_Strategy() {
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int n=s.nextInt();
            int m=s.nextInt();
            int k=s.nextInt();
            //dono side same bhrre jaaye ye leke chlo, uss hisabb s hisab lgao--> aage agr n bhrne h 2n-already days lgenge, already=n
            //min(w) wli side days=2w-1,then max(k)=2k-w --> 2k+w-1<=m h toh all
            //min(w) poora + bde wale m k(>w) -->k+w+1 mein honge
            //yaa dono side barabar(k)-->m-(3k-1)<2
            int bdi=n-k;
            int cht=k-1;
            if(bdi<cht){
                int l=bdi;
                bdi=cht;
                cht=l;
            }
            if(2*(bdi)+cht-1<=m) System.out.println(n);
            else{
                System.out.println(h_War_Strategy(m,cht,bdi)+1);//isme ye bhi ho skta h ki vo min s uper nikal jaaye
            }
        }
    }
    public static int h_War_Strateg(int m, int cht, int  bdi){
        int k=(int)((m+1)/3);
        if (k>cht){ //ye hoga jb min full wala case aayega
            int l=(m-(2*cht-1));//rem days for bigger 2*o-cht<=m--> o<=m+cht/2
            int o=(int)((l+cht)/2);
            return cht+Math.min(bdi,o);
        }
        if(m-(3*k-1)>1) return 2*k+1;
        return 2*k;
    }


