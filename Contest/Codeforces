    public static void Chipmunk_Theo_and_Equality() throws Exception {
        FastScanner fs = new FastScanner();
        StringBuilder output = new StringBuilder();
        long testCases = fs.nextLong();
        while (testCases-- > 0) {
            int n = (int) fs.nextLong();
            long[] numbers = new long[n];
            long minimumNumber = Long.MAX_VALUE;
            // store all numbers
            for (int i = 0; i < n; i++) {
                numbers[i] = fs.nextLong();
                minimumNumber = Math.min(minimumNumber, numbers[i]);
            }
            /*
             reachableTargets:
             Stores all candidate target values
             that we should consider.
            */
            HashSet<Long> reachableTargets = new HashSet<>();
            /*
             validTarget:
             acts like boolean map in C++
            */
            HashMap<Long, Boolean> validTarget = new HashMap<>();
            // Build all reachable values from minimum number
            validTarget.put(1L, true);
            validTarget.put(2L, true);
            reachableTargets.add(1L);
            reachableTargets.add(2L);
            if (minimumNumber != 1) {
                while (minimumNumber != 1) {
                    validTarget.put(minimumNumber, true);
                    reachableTargets.add(minimumNumber);
                    if ((minimumNumber & 1) == 1) {
                        minimumNumber++;
                    } else {
                        minimumNumber /= 2;
                    }
                }
            }
            /*
             reachCount[value]
             = how many numbers can reach this value
            */
            HashMap<Long, Long> reachCount = new HashMap<>();
            /*
             totalCost[value]
             = total operations needed for all numbers
               to reach this value
            */
            HashMap<Long, Long> totalCost = new HashMap<>();
            // Process every number
            for (long currentNumber : numbers) {
                long operations = 0;
                long x = currentNumber;
                // Special handling for odd number at start
                if ((x & 1) == 1) {
                    if (validTarget.containsKey(x)) {
                        reachCount.put(
                                x,
                                reachCount.getOrDefault(x, 0L) + 1
                        );
                        totalCost.put(
                                x,
                                totalCost.getOrDefault(x, 0L) + operations
                        );
                    }
                    x++;
                    operations++;
                    // if became 2
                    if (x == 2) {
                        if (validTarget.containsKey(x)) {
                            reachCount.put(
                                    x,
                                    reachCount.getOrDefault(x, 0L) + 1
                            );
                            totalCost.put(
                                    x,
                                    totalCost.getOrDefault(x, 0L) + operations
                            );
                        }
                        continue;
                    }
                }
                // Traverse transformation path
                while (x != 1) {
                    if (validTarget.containsKey(x)) {
                        reachCount.put(
                                x,
                                reachCount.getOrDefault(x, 0L) + 1
                        );
                        totalCost.put(
                                x,
                                totalCost.getOrDefault(x, 0L) + operations
                        );
                    }
                    operations++;
                    if ((x & 1) == 1) {
                        x++;
                    } else {
                        x /= 2;
                    }
                }
                // Final state = 1
                reachCount.put(
                        1L,
                        reachCount.getOrDefault(1L, 0L) + 1
                );
                totalCost.put(
                        1L,
                        totalCost.getOrDefault(1L, 0L) + operations
                );
            }
            // Find minimum answer
            long answer = Long.MAX_VALUE;
            for (long target : reachableTargets) {
                if (reachCount.getOrDefault(target, 0L) < n) {
                    continue;
                }
                answer = Math.min(
                        answer,
                        totalCost.get(target)
                );
            }
            output.append(answer).append('\n');
        }
        System.out.print(output);
    }

