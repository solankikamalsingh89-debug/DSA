    public static void Heapify_1(){
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int n=s.nextInt();
            int a[]=new int[n];
            boolean ans=true;
            // ArrayList<Integer> b=new ArrayList<>();
            for(int i=0;i<n;i++){
                a[i]=s.nextInt();
                if(!ans) continue;
                if(a[i]<i+1){
                    if((i+1)%a[i]!=0) ans=false;
                    else{
                        int q=(i+1)/a[i];
                        while(q>1){
                            if(q%2==1){
                                ans=false;
                                break;
                            }
                            q/=2;
                        }
                    }
                }
                else if(a[i]>i+1){
                    if(a[i]%(i+1)!=0) ans=false;
                    else{
                        int q=a[i]/(i+1);
                        while(q>1){
                            if(q%2==1){
                                ans=false;
                                break;
                            }
                            q/=2;
                        }
                    }
                }
            }
            if(ans) System.out.println("YES");
            else System.out.println("NO");
        }
    }

