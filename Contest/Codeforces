    public static int h_Huge_Pile(int n, int k, int a, HashSet<Integer> o){
        if(n==k) return a;
        if(o.contains(n)) return -1;
        if(n>k){
            if(n%2==0){
                int j= h(n/2,k,a+1,o);
                if(j==-1) {
                    o.add(n/2);
                    o.add(n);
                }
                return j;
            }
            else{
                int l=h(n/2,k,a+1,o);
                if(l==-1){
                    o.add(n/2);
                    int j= h((n/2)+1,k,a+1,o);
                    if(j==-1){
                        o.add((n/2)+1);
                        o.add(n);
                    }
                    return j;
                }
                return l;
            }
        }
        o.add(n);
        return -1;
    }

