    public static void Hourglass() {
        Scanner sc=new Scanner (System.in);
        int t=sc.nextInt();
        while(t-->0){
            int s=sc.nextInt();
            int k=sc.nextInt();
            int m=sc.nextInt();
            if(k==s){
                System.out.println(k-(m%k));
            }
            else if(k<s){
                int times=m/k;
                if(times%2==0){
                    System.out.println(s-(m%k));
                }
                else System.out.println(k-(m%k));
            }
            else{
                int r=m%k;
                if(r>=s) System.out.println(0);
                else System.out.println(s-r);
            }
        }
    }

