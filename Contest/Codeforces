            //HashSet<Integer>a1=new HashSet<>();
            int a3[]=new int[n-1];
            int a2[]=new int[p-1];
            for(int i=0;i<p-1;i++){
                a2[i]=a3[i]=s.nextInt();
            }
            //ArrayList<Integer>a2=new ArrayList<>();
            int pa=s.nextInt();
            for(int i=p;i<n;i++){
                a3[i-1]=s.nextInt();
            }
            Arrays.sort(a2);
            Arrays.sort(a3);
            int c=0;
            int ans=0;
            for(int i=0;i<p-k;i++){
                c+=a2[i];
                // System.out.println(c);
                // System.out.println((m-pa));
                if(c>m-pa){
                    ans=-2;
                    break;
                }
            }
            c+=pa;
            int rc=0;
            ans++;
            if (ans!=-1) {
                for(int i=0;i<n-k;i++){
                    rc+=a3[i];
                    if(rc+c>m-pa){
                        rc=-1;
                        break;
                    }
                }
                if(rc!=-1){
                    rc+=pa;
                    ans+=(m-c)/rc;
                }
                System.out.println(ans);
            }
            else System.out.println(0);
        }
    }

