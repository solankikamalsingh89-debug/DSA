            }
            for(long i=0;i<n;i++){
                for(long j=1;j<=a[(int)i] && j<n;j++){
                    if(i+j*a[(int)i]>=n && i-j*a[(int)i]<0) break;
                    if(i+j*a[(int)i]<n && a[(int)(i+j*a[(int)i])]==j) cnt++;
                    if(i-j*a[(int)i]>=0 && a[(int)(i-j*a[(int)i])]==j && a[(int)i]!=a[(int)(i-j*a[(int)i])]) cnt++;
                }
            }
            System.out.println(cnt);
        }
    }

