    public static void Shifted_MEX() {
        Scanner sc=new Scanner(System.in);
        int t=sc.nextInt();
        while(t-->0){
            int n=sc.nextInt();
            int q[]=new int[n];
            for(int i=0;i<n;i++){
                q[i]=sc.nextInt();
            }
            Arrays.sort(q);
            int m=1;
            int max=0;
            int p=q[0];
            for(int i=1;i<n;i++){
                if(q[i]==p+1) m++;
                else if(q[i]==p) continue;
                else{
                    max=Math.max(m,max);
                    m=1;
                }
                p=q[i];
            }
            System.out.println(Math.max(max,m));
        }
    }

    public static void OutOfMemoryError() {
        Scanner sc=new Scanner(System.in);
        int t=sc.nextInt();
        while(t-->0){
            int n=sc.nextInt();
            int m=sc.nextInt();
            int h=sc.nextInt();
            int q[]=new int[n];
            Stack<Integer> k=new Stack<>();
            for(int i=0;i<n;i++){
                q[i]=sc.nextInt();
            }
            for(int i=0;i<m;i++){
                int a=sc.nextInt()-1;
                int b=sc.nextInt();
                q[a]+=b;
                k.push(b);
                k.push(a);
                if(q[a]>h) {
                    while(!k.isEmpty()){
                        q[k.pop()]-=k.pop();
                    }
                }
            }
            for(int i=0;i<n;i++){
                System.out.print(q[i]);
                System.out.print(" ");
            }
            System.out.println();
        }
    }

    public static void Table_with_number() {
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int n=s.nextInt();
            int h=s.nextInt();
            int l=s.nextInt();
            if(h<l){
                int o=h;
                h=l;
                l=o;
            }
            int k=n;
            int c=0;
            for(int i=0;i<n;i++){
                int j=s.nextInt();
                if(j>h) k--;
                else if(j<=l) c++;
            }
            System.out.println(Math.min((int)k/2,c));
        }
