    public static void Shifted_MEX() {
        Scanner sc=new Scanner(System.in);
        int t=sc.nextInt();
        while(t-->0){
            int n=sc.nextInt();
            int q[]=new int[n];
            for(int i=0;i<n;i++){
                q[i]=sc.nextInt();
            }
            Arrays.sort(q);
            int m=1;
            int max=0;
            int p=q[0];
            for(int i=1;i<n;i++){
                if(q[i]==p+1) m++;
                else if(q[i]==p) continue;
                else{
                    max=Math.max(m,max);
                    m=1;
                }
                p=q[i];
            }
            System.out.println(Math.max(max,m));
        }
    }

