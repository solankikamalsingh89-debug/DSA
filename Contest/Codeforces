        }
    }
    private static boolean l_friendly_numbers(int x,int p){
        // x-=d(x);
        int y=d(x);
        if(x-y>p){
            while(x-y>=p){
                if(x-y==p) return true;
                x-=10;
                y=d(x);
            }
            return false;
        }
        else if(x-y==p) return true;
        else{
            while(x-y<=p){
                if(x-y==p) return true;
                x+=10;
                y=d(x);
            }
            return false;
        }
    }
    private static int d_friendly_numbers(int x){
        int h=0;
        while(x>0){
            h+=(x%10);
            x/=10;
        }
        return h;
    }

