	public static void Planting_roses() throws java.lang.Exception
	{
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int n=s.nextInt();
            long m=s.nextLong();//Potent to be filled
            long k=s.nextLong();
            int a[]=new int[n];
            long ans=0;
            for(int i=0;i<n;i++){
                int q=s.nextInt();
                if(m<=0) continue;
                a[i]=(int)(q%k);
                long p=(m)/(k+1); //Why faiiled on (m+1) at place of m--> 1 3 1 3 i.e. extra addition when going in else condition
                if(p>=q/k){
                    ans+=q-a[i];
                    m-=q-a[i]+q/k;
                }
                else{
                    ans+=p*k;
                    m-=p*(k+1);
                    ans+=m;
                    m=0;
                }
            }
            if(m>0) Arrays.sort(a);
            for(int i=n-1;i>=0 && a[i]!=0 && m>0;i--){
                ans+=Math.min(a[i],m);
                m-=(a[i]+1);
            }
            System.out.println(ans);
        }
	}

