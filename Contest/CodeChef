    public static void Non_Negative_Sum () throws java.lang.Exception
	{
		// your code goes here
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int n=s.nextInt();
            int ans=0;
            int p_sum=0;
            int k[]=new int[n];
            int j=0;
            for(int i=0;i<n;i++){
                int q=s.nextInt();
                if(q>=0) {
                    p_sum+=q;
                    ans++;
                }
                else{
                    k[j++]=q;
                }
            }
            Arrays.sort(k);
            for(int i=j-1;i>=0;i--){
                if(k[i]==0) break;
                p_sum+=k[i];
                if(p_sum>=0) ans++;
                else break;
            }
            System.out.println(ans);
        }
	}

