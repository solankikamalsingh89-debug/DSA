    public static void Sum_Reduction () throws java.lang.Exception
	{
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int n=s.nextInt();
            HashSet<Integer> a=new HashSet<>();
            boolean ans=true;
            while(n-->0){
                int q=s.nextInt();
                int p=0;
                while(q>0 && ans){
                    if(q%2==1){
                        if(a.contains(p)) ans=false;
                        else a.add(p);
                    }
                    q/=2;
                    p++;
                }
            }
