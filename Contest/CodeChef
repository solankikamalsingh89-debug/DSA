    public static void Draft_Picks() throws java.lang.Exception
	{
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int n=s.nextInt();
            int k=s.nextInt();
            long ans=0L;
            int q=(k)/(2*n);
            ans+=(2*q*k)+q-n*sum_Draft_Picks(q);
            ans+=Math.max(k-(2*q*n),2*(k-(2*q+1)*n)+1);
            System.out.println(ans);
        }
	}
	private static long sum_Draft_Picks(int a){
	    if(a==0) return 0L;
	    if(a==2) return 8L;
	    return ((a-1)*(a)*2)+2*a;
	}

    public static void Eventually_Equal() throws java.lang.Exception
	{
		Scanner s=new Scanner(System.in);
		int t=s.nextInt();
		while(t-->0){
		    int a=s.nextInt();
		    int b=s.nextInt();
		    int c=s.nextInt();
		    if(a==b) System.out.println(0);
		    else if(eventually_equal_helper_gcd(a,c)==eventually_equal_helper_gcd(b,c)) System.out.println(1);
		    else if(eventually_equal_helper_gcd(a,c+1)==eventually_equal_helper_gcd(b,c+1)) System.out.println(2);
		    else System.out.println(3);
		}
	}
	private static int eventually_equal_helper_gcd(int a, int b){
	    if(a==b || b==0) return a;
	    return eventually_equal_helper_gcd(b,a%b);
	}
