		            n/=10;
		        }
		        if(odd_found) System.out.println(1);
		        else{
		            System.out.println((f/max_digit)+2);
		        }
		    }
		}
	}

    public static void Rectangle_Coloring(){
        Scanner s=new Scanner(System.in);
        int t=s.nextInt();
        while(t-->0){
            int l=s.nextInt(), w=s.nextInt(), r=s.nextInt(), g=s.nextInt(), b=s.nextInt();
            if(l<w){
                int i=l;
                l=w;
                w=i;
            }
            if(b>g){
                int i=b;
                b=g;
                g=i;
            }
            if(g>r){
                int i=g;
                g=r;
                r=i;
            }
            if(dis_Rectangle_Coloring(l,w,r,g,b)) System.out.println(4);
            else if(r==(2*l+w) || r==(2*w+l) || r==2*l || r==w+l || r==2*w || g==2*w || b==2*w || r==l || r==w || g==l || g==w || b==l || b==w) System.out.println(5);
            else System.out.println(6);
        }
	}
	public static boolean dis_Rectangle_Coloring(int l,int w,int r,int g,int b){
	    if(w==b){
	        if((r==2*l && g==w) || (r==l+w && g==l)) return true;
	        return false;
	    }
	    else if(l==b){
	        if((r==l && g==2*w) || (r==2*w && g==l) || (r==l+w && g==w)) return true;
	        return false;
	    }
	    else if(b==2*w && r==l && g==l) return true;
	    return false;
	}

