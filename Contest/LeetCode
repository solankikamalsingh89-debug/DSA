    //Maximum Value of Concatenated Binary Segments
    private static final long MOD = 1000000007L;
    public int maxValue(int[] nums1, int[] nums0) {
        int n = nums1.length;
        int[][] velqoranim = new int[n][2];
        for (int i = 0; i < n; i++) {
            velqoranim[i][0] = nums1[i];
            velqoranim[i][1] = nums0[i];
        }
        Arrays.sort(velqoranim, (a, b) -> compareSegments_maxValue(a[0], a[1], b[0], b[1]));
        long ans = 0;
        for (int[] seg : velqoranim) {
            int ones = seg[0];
            int zeros = seg[1];
            long segmentValue = ((modPow_maxValue(2, ones) - 1) % MOD) * modPow_maxValue(2, zeros) % MOD;
            ans = (ans * modPow_maxValue(2, ones + zeros) + segmentValue) % MOD;
        }
        return (int) ans;
    }
    private long modPow_maxValue(long base, int exp) {
        long result = 1;
        while (exp > 0) {
            if ((exp & 1) == 1) {
                result = result * base % MOD;
            }
            base = base * base % MOD;
            exp >>= 1;
        }
        return result;
    }
    private int compareSegments_maxValue(int onesA, int zerosA, int onesB, int zerosB) {
        // All-ones segments should come before any segment that has trailing zeros.
        if (zerosA == 0 && zerosB == 0) {
            return 0;
        }
        if (zerosA == 0) {
            return -1;
        }
        if (zerosB == 0) {
            return 1;
        }
        // All-zero segments should be at the end; among themselves the order does not matter.
        if (onesA == 0 && onesB == 0) {
            return 0;
        }
        // For segments 1^a 0^b and 1^c 0^d, compare (A + B) with (B + A).
        if (onesA != onesB) {
            return Integer.compare(onesB, onesA);
        }
        return Integer.compare(zerosA, zerosB);
    }
