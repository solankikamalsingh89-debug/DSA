    //Find the Smallest Balanced Index
    public int smallestBalancedIndex(int[] nums) {
        long sum=0;
        long pr=1;
        int p_i=0;
        while(p_i<nums.length){
            if(Math.log10(pr)+Math.log10(nums[p_i])<18){
                pr*=nums[p_i];
                p_i++;
            }
            else break;
        }
        for(int i=0;i<nums.length;i++){
            if(i>0) sum+=nums[i-1];
            pr/=nums[i];
            while(p_i<nums.length){
                if(Math.log10(pr)+Math.log10(nums[p_i])<18){
                    pr*=nums[p_i];
                    p_i++;
                }
                else break;
            }
            if(p_i==nums.length && sum==pr) return i;    
        }
        return -1;
    }

    //Minimum Operations to Sort a String
    public int minOperations(String s) {
        int n=s.length();
        if(n==1) return 0;
        else if(n==2 && s.charAt(1)-s.charAt(0)<0) return -1;
        else{
            boolean a=true;
            int min_o=0,max_o=0;
            int min=s.charAt(0)-'a',max=s.charAt(0)-'a';
            for(int i=0;i<n;i++){
                if(s.charAt(i)-'a'<min) {
                    min=(int)(s.charAt(i)-'a');
                    min_o=1;
                }
                else if(s.charAt(i)-'a'==min){
                    min_o++;
                }
                if(s.charAt(i)-'a'>max) {
                    max=(int)(s.charAt(i)-'a');
                }
                else if(s.charAt(i)-'a'==max) max_o++;
                else a=false;
            }
            if(a) return 0;
            else if(s.charAt(0)-'a'==min || s.charAt(n-1)-'a'==max) return 1;
            else if(s.charAt(n-1)-'a'==min && s.charAt(0)-'a'==max && min_o*max_o==1) return 3;
            return 2;
        }
    }

    //Minimum Cost to Partition a Binary String
    public long minCost(String s, int encCost, int flatCost) {
        int n = s.length();
        int[] prefix=new int[n + 1];
        for (int i = 0; i < n; i++) {
            prefix[i + 1] = prefix[i] + (s.charAt(i) - '0');
        }
        return minCost_solve(0, n - 1, encCost, flatCost, prefix);
    }
    private long minCost_solve(int l, int r, int x, int y, int prefix[]) {
        int ones = prefix[r + 1] - prefix[l];

        long cost;

        if (prefix[r + 1] - prefix[l] == 0) cost = y;
        else cost = (long) (r-l+1) * (prefix[r + 1] - prefix[l]) * x;

        if ((r-l) % 2 == 0) {
            return cost;
        }

        return Math.min(cost,minCost_solve(l, (l + r) / 2, x, y, prefix) + minCost_solve((l + r) / 2 + 1, r, x, y, prefix));
    }

